-- ESP Functions
local espBoxColor = colors.accent
local espNameColor = colors.text

function setupESP()
    clearESP()
    RunService.RenderStepped:Connect(function()
        if not espEnabled then return end
        updateESP()
    end)
end

function updateESP()
    clearESP()
    
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild("Humanoid") and player.Character.Humanoid.Health > 0 then
            local character = player.Character
            local rootPart = character:FindFirstChild("HumanoidRootPart") or character:FindFirstChild("Torso")
            if rootPart and Camera then
                local vector, onScreen = Camera:WorldToScreenPoint(rootPart.Position)
                if onScreen then
                    local yOffset = 3
                    local headPos = character:FindFirstChild("Head")
                    local headScreen = headPos and Camera:WorldToScreenPoint(headPos.Position) or vector
                    
                    if espOptions["Box ESP"] then
                        createBoxESP(vector, headScreen, player, espBoxColor)
                    end
                    
                    if espOptions["Name ESP"] then
                        createNameESP(vector, player, espNameColor)
                    end
                    
                    if espOptions["Distance ESP"] then
                        createDistanceESP(vector, player)
                    end
                    
                    if espOptions["Health Bar"] then
                        createHealthBar(vector, player)
                    end
                    
                    if espOptions["Tracer Line"] then
                        createTracer(vector, player)
                    end
                end
            end
        end
    end
end

function createBoxESP(vector, headScreen, player, color)
    local box = Instance.new("Frame")
    box.Size = UDim2.new(0, 40, 0, 60)
    box.Position = UDim2.new(0, vector.X - 20, 0, headScreen.Y - 60)
    box.BackgroundColor3 = color
    box.BackgroundTransparency = 0.7
    box.BorderSizePixel = 1
    box.BorderColor3 = color
    box.Parent = screenGui
    
    local boxCorner = Instance.new("UICorner")
    boxCorner.CornerRadius = UDim.new(0, 4)
    boxCorner.Parent = box
    
    table.insert(espObjects, box)
end

function createNameESP(vector, player, color)
    local nameLabel = Instance.new("TextLabel")
    nameLabel.Size = UDim2.new(0, 100, 0, 20)
    nameLabel.Position = UDim2.new(0, vector.X - 50, 0, vector.Y - 70)
    nameLabel.BackgroundTransparency = 1
    nameLabel.Text = player.Name
    nameLabel.TextColor3 = color
    nameLabel.TextSize = 12
    nameLabel.Font = Enum.Font.GothamBold
    nameLabel.TextStrokeTransparency = 0.5
    nameLabel.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
    nameLabel.Parent = screenGui
    
    table.insert(espObjects, nameLabel)
end

function createDistanceESP(vector, player)
    local distance = (LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") and 
                     player.Character.HumanoidRootPart.Position - LocalPlayer.Character.HumanoidRootPart.Position).Magnitude
    local distanceText = Instance.new("TextLabel")
    distanceText.Size = UDim2.new(0, 50, 0, 15)
    distanceText.Position = UDim2.new(0, vector.X - 25, 0, vector.Y - 50)
    distanceText.BackgroundTransparency = 1
    distanceText.Text = math.floor(distance) .. "m"
    distanceText.TextColor3 = Color3.fromRGB(200, 200, 200)
    distanceText.TextSize = 10
    distanceText.Font = Enum.Font.Gotham
    distanceText.Parent = screenGui
    
    table.insert(espObjects, distanceText)
end

function createHealthBar(vector, player)
    local health = player.Character.Humanoid.Health
    local maxHealth = player.Character.Humanoid.MaxHealth
    local healthPercent = health / maxHealth
    
    local healthBg = Instance.new("Frame")
    healthBg.Size = UDim2.new(0, 40, 0, 5)
    healthBg.Position = UDim2.new(0, vector.X - 20, 0, vector.Y + 15)
    healthBg.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
    healthBg.BorderSizePixel = 0
    healthBg.Parent = screenGui
    
    local healthFill = Instance.new("Frame")
    healthFill.Size = UDim2.new(healthPercent, 0, 1, 0)
    healthFill.BackgroundColor3 = Color3.fromRGB(80, 220, 80)
    healthFill.BorderSizePixel = 0
    healthFill.Parent = healthBg
    
    table.insert(espObjects, healthBg)
    table.insert(espObjects, healthFill)
end

function createTracer(vector, player)
    local cameraPos = Camera.CFrame.Position
    local playerPos = player.Character.HumanoidRootPart.Position
    local screenPoint = Camera:WorldToScreenPoint(playerPos)
    
    local tracer = Instance.new("Frame")
    tracer.Size = UDim2.new(0, 2, 0, screenPoint.Y)
    tracer.Position = UDim2.new(0, screenPoint.X - 1, 0, screenPoint.Y)
    tracer.BackgroundColor3 = colors.accent
    tracer.BackgroundTransparency = 0.5
    tracer.BorderSizePixel = 0
    tracer.Parent = screenGui
    
    table.insert(espObjects, tracer)
end

function clearESP()
    for _, obj in pairs(espObjects) do
        if obj and obj.Parent then
            obj:Destroy()
        end
    end
    espObjects = {}
end

function refreshESP()
    clearESP()
    updateESP()
end


local function createRow(name, order)
	local row = Instance.new("Frame", scrollFrame)
	row.Name = name
	row.Size = UDim2.new(1,0,0,rowH)
	row.BackgroundColor3 = C_ROW
	row.BackgroundTransparency = BG_TRANS
	row.BorderSizePixel = 0
	row.LayoutOrder = order; row.ZIndex = 3

	local div = Instance.new("Frame", row)
	div.Size = UDim2.new(1,0,0,1); div.Position = UDim2.new(0,0,1,-1)
	div.BackgroundColor3 = C_DIVIDER; div.BackgroundTransparency = 0.2
	div.BorderSizePixel = 0; div.ZIndex = 4

	local lbl = Instance.new("TextLabel", row)
	lbl.Size = UDim2.new(1,-72,1,0); lbl.Position = UDim2.new(0,14,0,0)
	lbl.BackgroundTransparency = 1; lbl.Text = name
	lbl.TextColor3 = C_TEXT; lbl.TextSize = isMobile and 13 or 14
	lbl.Font = Enum.Font.GothamBold
	lbl.TextXAlignment = Enum.TextXAlignment.Left; lbl.ZIndex = 4

	local track = Instance.new("Frame", row)
	track.Size = UDim2.new(0,46,0,26); track.Position = UDim2.new(1,-56,0.5,-13)
	track.BackgroundColor3 = C_TRACK_OFF; track.BorderSizePixel = 0; track.ZIndex = 4
	Instance.new("UICorner", track).CornerRadius = UDim.new(1,0)
	local tSt = Instance.new("UIStroke", track)
	tSt.Color = Color3.fromRGB(55,55,72); tSt.Thickness = 1; tSt.Transparency = 0.1

	local knob = Instance.new("Frame", track)
	knob.Size = UDim2.new(0,20,0,20); knob.Position = UDim2.new(0,3,0.5,-10)
	knob.BackgroundColor3 = C_KNOB_OFF; knob.BorderSizePixel = 0; knob.ZIndex = 5
	Instance.new("UICorner", knob).CornerRadius = UDim.new(1,0)

	local btn = Instance.new("TextButton", row)
	btn.Size = UDim2.new(1,0,1,0); btn.BackgroundTransparency = 1
	btn.Text = ""; btn.ZIndex = 6

	local isOn = false
	local function set(state)
		isOn = state
		TweenService:Create(knob, TweenInfo.new(0.22, Enum.EasingStyle.Back, Enum.EasingDirection.Out),
			{Position = state and UDim2.new(1,-23,0.5,-10) or UDim2.new(0,3,0.5,-10),
			 BackgroundColor3 = state and Color3.fromRGB(255,255,255) or C_KNOB_OFF}):Play()
		TweenService:Create(track, TweenInfo.new(0.22, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
			{BackgroundColor3 = state and C_BLUE or C_TRACK_OFF}):Play()
		TweenService:Create(tSt, TweenInfo.new(0.18),
			{Color = state and C_BLUE_DIM or Color3.fromRGB(55,55,72)}):Play()
		if state then
			local rip = Instance.new("Frame", row)
			rip.Size = UDim2.new(0,0,0,0); rip.Position = UDim2.new(0.5,0,0.5,0)
			rip.BackgroundColor3 = C_BLUE; rip.BackgroundTransparency = 0.72
			rip.BorderSizePixel = 0; rip.ZIndex = 5
			Instance.new("UICorner", rip).CornerRadius = UDim.new(1,0)
			TweenService:Create(rip, TweenInfo.new(0.4, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
				{Size=UDim2.new(0,220,0,220),
				 Position=UDim2.new(0.5,-110,0.5,-110),
				 BackgroundTransparency=1}):Play()
			task.delay(0.4, function() rip:Destroy() end)
		end
	end

	btn.MouseButton1Click:Connect(function() set(not isOn) end)
	btn.MouseEnter:Connect(function()
		TweenService:Create(row,TweenInfo.new(0.1),{BackgroundTransparency=0.1}):Play()
	end)
	btn.MouseLeave:Connect(function()
		TweenService:Create(row,TweenInfo.new(0.1),{BackgroundTransparency=BG_TRANS}):Play()
	end)
end

for i, t in ipairs(TOGGLES) do

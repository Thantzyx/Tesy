local function loopShimmer()
	barShimmer.Position = UDim2.new(-0.3,0,0,0)
	local t = TweenService:Create(barShimmer,
		TweenInfo.new(0.85, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut),
